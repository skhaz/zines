                   sizeof(struct udphdr) + psize,
                   0, (struct sockaddr *) &dstaddr,
                   sizeof(struct sockaddr_in)) == (-1)) {
            puts("[*] Error sending Packet");
            perror("SendPacket");
            exit(EXIT_FAILURE);
        }
        usleep(wait);
    }
}

