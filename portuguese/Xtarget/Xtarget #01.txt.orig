========================%> PASCAL II (O Retorno) <%=========================
                             By SeQ MaSsÎvEź



Continuando o básico, vc's agora văo saber um pouco mais sobre, 

IF -> THEN -> ELSE... etc..
WHILE -> DO -> UNTIL ///


Supondo que vc tente entrar como root em um sys..

(*********************** CORTA **********************)


program Senha;
uses crt;

var
   login,passwd:string[50];

(* Declarando as variaveis copo, agua etc... *)

begin
     
     clrscr;
     
     FOR i := 1 to 3 do (* o FOR serve para o numero de tentativas do 
programa... *)
     
     write('login: ');
     read(login);
	write('passwd: '); 	
	read(passwd);

(* Na parte acima, ele jogará na memória, em duas variaveis diferentes 
o login e a senha *)

	IF login = ('root') and passwd = ('root')
		THEN
		    writeln('ACESSO EFETUADO COM SUCESSO')
	ELSE
	    writeln('LOGIN INCORRETO');

(******************* Aqui explica bem o IF THEN ELSE, ou seja, 

	SE login é igual a root e o passwd é igual a root ENTĂO
		Escreva('ACESSO ....')
        SENĂO
	     Escreva('LOGIN INCORRETO...');

********************)	


	while not keypressed do; (*** Isto é para sair do programa 
precionando qqer tecla apóso programa ter terminado... **)

(** Você pode também usar**)


{ repeat until keypressed; }




end. (*** Isto é o FIM do programa... DDDDEEEEERRRRR ***)

(*********************** CORTA **********************)



WHILE DO /////////


O While é usado para isso:

----CORTA----


program repete;
uses crt;
var
   x:integer;
begin
     clrscr;
     write('Digite um Numero (Para encerrar digite um numero 
negativo): ');
     readln(x);
               while x >= 0 do
               begin
                    if (x>0) and (x<10);
                       then
                           writeln('X = ', x);
               write('Digite outro: ');
               readln(x);
               end;
     repeat until keypressed
end.


(** Neste programa ele pedirá para digitar um número... mas ele irá 
imprimir todos os números maiores que 0 e menores que 10, senăo ele 
pedirá outro número, até que vc saia do prog digitando um número 
negativo **)


----CORTA----


